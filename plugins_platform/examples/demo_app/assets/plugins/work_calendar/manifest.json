{
  "id": "com.company.work_calendar",
  "name": "工作日历",
  "description": "集成日程管理、会议安排、审批提醒",
  "version": "1.0.0",
  "publisher": "company",
  "type": "js",
  "platforms": [
    "ios",
    "android",
    "windows",
    "macos",
    "linux"
  ],
  "minHostVersion": "1.0.0",
  "engine": {
    "runtime": "quickjs",
    "bundle": "dist/bundle.js",
    "bundleHash": "38d6a6a5cb55550838bf5bdeeac67e7945bf0fedb0c31199a41991c05700f13f",
    "bundleSize": 63300,
    "entryFunction": "onActivate",
    "memoryLimitMb": 16,
    "executionTimeoutMs": 5000,
    "background": false
  },
  "activationEvents": [
    "onCommand:calendar.open",
    "onEvent:approval.created"
  ],
  "permissions": [
    "storage.local",
    "toast.show",
    "dialog.alert",
    "calendar.read",
    "calendar.write",
    "org.contacts.read",
    "notification.send",
    "approval.read",
    "approval.write"
  ],
  "capabilities": [
    {
      "id": "calendar.event.get",
      "type": "data",
      "permissions": [
        "calendar.read"
      ]
    },
    {
      "id": "calendar.event.create",
      "type": "action",
      "permissions": [
        "calendar.write"
      ]
    }
  ],
  "stac": {
    "schemaVersion": "1.0",
    "components": [
      "text",
      "button",
      "textFormField",
      "textarea",
      "container",
      "row",
      "column",
      "gridView",
      "card",
      "iconButton",
      "expanded",
      "sizedBox"
    ],
    "customComponents": []
  },
  "performanceBudget": {
    "startupMs": 800,
    "firstScreenMs": 1500,
    "maxMemoryMb": 16,
    "maxCpuPercent": 10
  },
  "updatePolicy": {
    "channel": "stable",
    "allowAutoUpdate": true,
    "allowRollback": true,
    "allowRemoteConfig": true,
    "allowRemoteSchema": true,
    "allowRemoteCode": true,
    "signatureRequired": false
  }
}
